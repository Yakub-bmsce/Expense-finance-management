# Server Port
PORT=5000

# Database URL (Postgres Connection String)
# Local: postgresql://username:password@localhost:5432/flatsplit
# Neon: postgres://<user>:<password>@<endpoint>.neon.tech/flatsplit?sslmode=require
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/flatsplit

# JWT Secret Key
JWT_SECRET=supersecretjwtkeychangeinproduction

# Environment Mode
NODE_ENV=development

# Frontend URL for CORS
FRONTEND_URL=http://localhost:5173

# Google OAuth Credentials (for Phase 1 OAuth login - can be placeholder or configured)
GOOGLE_CLIENT_ID=your-google-client-id
GOOGLE_CLIENT_SECRET=your-google-client-secret
